<UserControl
  x:Class="LabsResponsiveShell.Shell.IdentityChip"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Grid x:Name="Root">

    <!-- desktop: compact pill at rail footer, flyout opens up-and-right -->
    <Border x:Name="DesktopLayout"
            Height="44"
            HorizontalAlignment="Stretch"
            Background="Transparent"
            BorderBrush="{ThemeResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="22"
            Visibility="Collapsed">
      <Button Background="Transparent"
              BorderThickness="0"
              CornerRadius="22"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Left"
              Padding="6,0,14,0">
        <Button.Resources>
          <ResourceDictionary>
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{ThemeResource HoverColor}" />
            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{ThemeResource HoverColor}" />
            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
          </ResourceDictionary>
        </Button.Resources>
        <Button.Flyout>
          <Flyout Placement="TopEdgeAlignedLeft">
            <StackPanel Width="240" Spacing="{StaticResource Space12}">
              <TextBlock Style="{StaticResource EyebrowText}"
                         Text="PREFERENCES" />
              <ToggleSwitch Header="Dark theme"
                            IsOn="{Binding IsDarkTheme, Mode=TwoWay}" />
              <ToggleSwitch Header="Right to left"
                            IsOn="{Binding IsRightToLeft, Mode=TwoWay}" />
              <ToggleSwitch Header="Reduced motion"
                            IsOn="{Binding IsReducedMotion, Mode=TwoWay}" />
            </StackPanel>
          </Flyout>
        </Button.Flyout>

        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="{StaticResource Space8}"
              VerticalAlignment="Center">
          <Grid Grid.Column="0" Width="32" Height="32">
            <Ellipse Fill="{ThemeResource SurfaceElevatedBrush}" />
            <TextBlock Text="Q"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontFamily="{StaticResource PrimaryFontFamily}"
                       FontSize="{StaticResource FontSize14}"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextBrush}" />
            <Ellipse Width="9"
                     Height="9"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Fill="#3FB980"
                     Stroke="{ThemeResource SurfaceBrush}"
                     StrokeThickness="2" />
          </Grid>
          <TextBlock Grid.Column="1"
                     Text="qaiser"
                     FontFamily="{StaticResource PrimaryFontFamily}"
                     FontSize="{StaticResource FontSize14}"
                     FontWeight="Medium"
                     Foreground="{ThemeResource TextBrush}"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" />
        </Grid>
      </Button>
    </Border>

    <!-- mobile: avatar-only, flyout opens down-and-left -->
    <Button x:Name="MobileLayout"
            Background="Transparent"
            BorderThickness="0"
            CornerRadius="18"
            Padding="0"
            Width="36"
            Height="36"
            VerticalAlignment="Center"
            Visibility="Collapsed">
      <Button.Resources>
        <ResourceDictionary>
          <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent" />
          <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent" />
          <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
          <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
        </ResourceDictionary>
      </Button.Resources>
      <Button.Flyout>
        <Flyout Placement="BottomEdgeAlignedRight">
          <StackPanel Width="240" Spacing="{StaticResource Space12}">
            <TextBlock Style="{StaticResource EyebrowText}"
                       Text="PREFERENCES" />
            <ToggleSwitch Header="Dark theme"
                          IsOn="{Binding IsDarkTheme, Mode=TwoWay}" />
            <ToggleSwitch Header="Right to left"
                          IsOn="{Binding IsRightToLeft, Mode=TwoWay}" />
            <ToggleSwitch Header="Reduced motion"
                          IsOn="{Binding IsReducedMotion, Mode=TwoWay}" />
          </StackPanel>
        </Flyout>
      </Button.Flyout>
      <Grid Width="32" Height="32">
        <Ellipse Fill="{ThemeResource SurfaceElevatedBrush}" />
        <TextBlock Text="Q"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontFamily="{StaticResource PrimaryFontFamily}"
                   FontSize="{StaticResource FontSize14}"
                   FontWeight="SemiBold"
                   Foreground="{ThemeResource TextBrush}" />
        <Ellipse Width="9"
                 Height="9"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Fill="#3FB980"
                 Stroke="{ThemeResource SurfaceBrush}"
                 StrokeThickness="2" />
      </Grid>
    </Button>

    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup x:Name="Variants">
        <VisualState x:Name="MobileVariant">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="0" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="MobileLayout.Visibility" Value="Visible" />
            <Setter Target="DesktopLayout.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>
        <VisualState x:Name="DesktopVariant">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="768" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="DesktopLayout.Visibility" Value="Visible" />
            <Setter Target="MobileLayout.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

  </Grid>

</UserControl>
