<Page
  x:Class="LabsResponsiveShell.Shell.AppShell"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:shell="using:LabsResponsiveShell.Shell"
  Background="{ThemeResource BgBrush}"
  Foreground="{ThemeResource TextBrush}">

  <Grid x:Name="RootGrid"
        ColumnDefinitions="*"
        RowDefinitions="*">

    <!-- wide: vertical nav rail left, content right -->
    <Grid x:Name="WideLayout"
          ColumnDefinitions="240,*"
          Visibility="Collapsed">
      <Grid Grid.Column="0"
            Background="{ThemeResource SurfaceBrush}"
            BorderBrush="{ThemeResource BorderBrush}"
            BorderThickness="0,0,1,0"
            Padding="{StaticResource Space16}"
            RowDefinitions="Auto,*,Auto">
        <TextBlock Grid.Row="0"
                   Text="labs"
                   FontFamily="{StaticResource PrimaryFontFamily}"
                   FontSize="{StaticResource FontSize20}"
                   FontWeight="SemiBold"
                   Foreground="{ThemeResource TextBrush}"
                   Margin="0,0,0,24" />
        <StackPanel Grid.Row="1" Spacing="{StaticResource Space4}">
          <shell:NavItem x:Name="WideHomeItem"
                         Click="OnNavigateHome"
                         IconData="{StaticResource IconHomeData}"
                         Label="Home" />
          <shell:NavItem x:Name="WideChatItem"
                         Click="OnNavigateChat"
                         IconData="{StaticResource IconChatData}"
                         Label="Chat" />
          <shell:NavItem x:Name="WideSettingsItem"
                         Click="OnNavigateSettings"
                         IconData="{StaticResource IconSettingsData}"
                         Label="Settings" />
        </StackPanel>
        <shell:IdentityChip Grid.Row="2" />
      </Grid>
      <Frame x:Name="WideContentFrame" Grid.Column="1" Background="Transparent" />
    </Grid>

    <!-- narrow: top bar, content, bottom tabs -->
    <Grid x:Name="NarrowLayout"
          RowDefinitions="Auto,*,Auto"
          Visibility="Collapsed">
      <Grid Grid.Row="0"
            Background="{ThemeResource SurfaceBrush}"
            BorderBrush="{ThemeResource BorderBrush}"
            BorderThickness="0,0,0,1"
            ColumnDefinitions="*,Auto"
            Padding="{StaticResource Space16}">
        <TextBlock Grid.Column="0"
                   Text="labs"
                   FontFamily="{StaticResource PrimaryFontFamily}"
                   FontSize="{StaticResource FontSize20}"
                   FontWeight="SemiBold"
                   Foreground="{ThemeResource TextBrush}"
                   VerticalAlignment="Center" />
        <shell:IdentityChip Grid.Column="1" />
      </Grid>
      <Frame x:Name="NarrowContentFrame" Grid.Row="1" Background="Transparent" />
      <Grid Grid.Row="2"
            Background="{ThemeResource SurfaceBrush}"
            BorderBrush="{ThemeResource BorderBrush}"
            BorderThickness="0,1,0,0"
            ColumnDefinitions="*,*,*"
            Padding="{StaticResource Space8}">
        <shell:TabItem x:Name="NarrowHomeItem"
                       Grid.Column="0"
                       Click="OnNavigateHome"
                       IconData="{StaticResource IconHomeData}"
                       Label="Home" />
        <shell:TabItem x:Name="NarrowChatItem"
                       Grid.Column="1"
                       Click="OnNavigateChat"
                       IconData="{StaticResource IconChatData}"
                       Label="Chat" />
        <shell:TabItem x:Name="NarrowSettingsItem"
                       Grid.Column="2"
                       Click="OnNavigateSettings"
                       IconData="{StaticResource IconSettingsData}"
                       Label="Settings" />
      </Grid>
    </Grid>

    <!-- skeleton overlay: briefly covers tab switches; Home draws its own hero glow -->
    <Border x:Name="SkeletonOverlay"
            Grid.Column="0"
            Background="{ThemeResource BgBrush}"
            Opacity="0"
            IsHitTestVisible="False">
      <StackPanel Margin="24,28,24,32"
                  MaxWidth="960"
                  HorizontalAlignment="Left"
                  Spacing="18">
        <Rectangle Height="20"
                   Width="140"
                   HorizontalAlignment="Left"
                   RadiusX="4"
                   RadiusY="4"
                   Fill="{ThemeResource SurfaceElevatedBrush}" />
        <Border Height="96"
                Background="{ThemeResource SurfaceElevatedBrush}"
                CornerRadius="{StaticResource Radius16}" />
        <Rectangle Height="14"
                   Width="180"
                   HorizontalAlignment="Left"
                   RadiusX="4"
                   RadiusY="4"
                   Fill="{ThemeResource SurfaceElevatedBrush}" />
        <Border Height="64"
                Background="{ThemeResource SurfaceElevatedBrush}"
                CornerRadius="{StaticResource Radius12}" />
        <Border Height="64"
                Background="{ThemeResource SurfaceElevatedBrush}"
                CornerRadius="{StaticResource Radius12}" />
        <Border Height="64"
                Background="{ThemeResource SurfaceElevatedBrush}"
                CornerRadius="{StaticResource Radius12}" />
      </StackPanel>
    </Border>

    <!-- toast host: one element, bottom center, visible on demand -->
    <Border x:Name="ToastHost"
            Grid.Column="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,36"
            Background="{ThemeResource SurfaceElevatedBrush}"
            BorderBrush="{ThemeResource AccentMutedBrush}"
            BorderThickness="1"
            CornerRadius="999"
            Padding="18,10,18,10"
            Opacity="0"
            IsHitTestVisible="False">
      <Border.RenderTransform>
        <TranslateTransform />
      </Border.RenderTransform>
      <TextBlock x:Name="ToastText"
                 FontFamily="{StaticResource PrimaryFontFamily}"
                 FontSize="{StaticResource FontSize14}"
                 Foreground="{ThemeResource TextBrush}" />
    </Border>

    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup x:Name="Breakpoint">
        <VisualState x:Name="NarrowState">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="0" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="NarrowLayout.Visibility" Value="Visible" />
            <Setter Target="WideLayout.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>
        <VisualState x:Name="WideState">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="768" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="WideLayout.Visibility" Value="Visible" />
            <Setter Target="NarrowLayout.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

  </Grid>

</Page>
