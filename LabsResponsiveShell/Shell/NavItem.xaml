<UserControl
  x:Class="LabsResponsiveShell.Shell.NavItem"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Button x:Name="HitButton"
          Click="OnClick"
          Background="Transparent"
          BorderThickness="0"
          HorizontalAlignment="Stretch"
          HorizontalContentAlignment="Stretch"
          VerticalContentAlignment="Stretch"
          Padding="8,8"
          CornerRadius="{StaticResource Radius8}">
    <Button.Resources>
      <ResourceDictionary>
        <!-- why: XamlControlsResources paints button hover with system accent; our hover is a subtle surface tone -->
        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent" />
        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent" />
        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
      </ResourceDictionary>
    </Button.Resources>

    <Grid x:Name="LayoutRoot"
          ColumnDefinitions="3,Auto,*"
          Background="Transparent"
          CornerRadius="{StaticResource Radius8}"
          Padding="0,6">
      <Rectangle x:Name="SelectedIndicator"
                 Grid.Column="0"
                 Width="3"
                 Height="18"
                 RadiusX="2"
                 RadiusY="2"
                 HorizontalAlignment="Left"
                 Fill="{ThemeResource AccentBrush}"
                 Opacity="0" />
      <PathIcon x:Name="Icon"
                Grid.Column="1"
                Width="18"
                Height="18"
                Margin="10,0,12,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextMutedBrush}" />
      <TextBlock x:Name="LabelText"
                 Grid.Column="2"
                 FontFamily="{StaticResource PrimaryFontFamily}"
                 FontSize="{StaticResource FontSize14}"
                 VerticalAlignment="Center"
                 Foreground="{ThemeResource TextBrush}" />

      <VisualStateManager.VisualStateGroups>
        <VisualStateGroup x:Name="HoverStates">
          <VisualState x:Name="Rest" />
          <VisualState x:Name="Hover">
            <VisualState.Setters>
              <Setter Target="LayoutRoot.Background" Value="{ThemeResource HoverBrush}" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
        <VisualStateGroup x:Name="SelectionStates">
          <VisualState x:Name="Unselected" />
          <VisualState x:Name="Selected">
            <VisualState.Setters>
              <Setter Target="SelectedIndicator.Opacity" Value="1" />
              <Setter Target="Icon.Foreground" Value="{ThemeResource AccentBrush}" />
              <Setter Target="LabelText.FontWeight" Value="SemiBold" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateManager.VisualStateGroups>
    </Grid>
  </Button>

</UserControl>
