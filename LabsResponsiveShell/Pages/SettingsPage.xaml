<Page
  x:Class="LabsResponsiveShell.Pages.SettingsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  Foreground="{ThemeResource TextBrush}">

  <ScrollViewer>
    <StackPanel Padding="{StaticResource Space32}"
                Spacing="{StaticResource Space24}"
                MaxWidth="{StaticResource ReadingColumnMaxWidth}"
                HorizontalAlignment="Left">

      <StackPanel Spacing="{StaticResource Space8}">
        <TextBlock Style="{StaticResource EyebrowText}"
                   Text="PREFERENCES" />
        <TextBlock Style="{StaticResource TitleText}"
                   Text="Settings" />
      </StackPanel>

      <Border Background="{ThemeResource SurfaceBrush}"
              BorderBrush="{ThemeResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="{StaticResource Radius12}"
              Padding="{StaticResource Space24}">
        <StackPanel Spacing="{StaticResource Space16}">
          <TextBlock Style="{StaticResource EyebrowText}"
                     Text="APPEARANCE" />
          <ToggleSwitch Header="Dark theme"
                        IsOn="{Binding IsDarkTheme, Mode=TwoWay}" />
          <ToggleSwitch Header="Right to left"
                        IsOn="{Binding IsRightToLeft, Mode=TwoWay}" />
          <ToggleSwitch Header="Reduced motion"
                        IsOn="{Binding IsReducedMotion, Mode=TwoWay}" />
        </StackPanel>
      </Border>

      <StackPanel Spacing="{StaticResource Space8}">
        <TextBlock Style="{StaticResource EyebrowText}"
                   Text="ABOUT THIS LAB" />
        <TextBlock Style="{StaticResource BodyText}"
                   Text="labs-responsive-shell is a minimal Uno Platform sample. It demonstrates a responsive shell, a token-driven style layer, and reduced-motion awareness. No network, no telemetry, no auth." />
        <HyperlinkButton NavigateUri="https://github.com/yottaverseltd/labs-responsive-shell"
                         Padding="0"
                         Content="github.com/yottaverseltd/labs-responsive-shell" />
      </StackPanel>

    </StackPanel>
  </ScrollViewer>

</Page>
