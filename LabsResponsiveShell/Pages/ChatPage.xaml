<Page x:Class="LabsResponsiveShell.Pages.ChatPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:LabsResponsiveShell.Controls"
      Background="Transparent"
      Foreground="{ThemeResource TextBrush}">

  <Grid x:Name="Root">
    <!-- wide: rail + chrome -->
    <Grid x:Name="WideChrome" Visibility="Collapsed">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="328" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Border Grid.Column="0"
              Background="{ThemeResource SurfaceBrush}"
              BorderBrush="{ThemeResource BorderBrush}"
              BorderThickness="0,0,1,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <Grid RowDefinitions="Auto,*" Padding="{StaticResource InsetChatRail}">
            <TextBox Grid.Row="0"
                     IsReadOnly="True"
                     IsHitTestVisible="False"
                     Opacity="0.52"
                     PlaceholderText="Search conversations"
                     Padding="14"
                     Margin="{StaticResource InsetSearchWide}"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Top" />
            <StackPanel x:Name="WideRowStack" Grid.Row="1" Spacing="2" />
          </Grid>
        </ScrollViewer>
      </Border>
      <controls:ChatConversationChrome x:Name="WideThreadChrome"
                                       Grid.Column="1"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch" />
    </Grid>

    <!-- narrow list -->
    <Grid x:Name="NarrowListPane" Visibility="Collapsed">
      <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource Space24}">
        <Grid RowDefinitions="Auto,*">
          <TextBox Grid.Row="0"
                   IsReadOnly="True"
                   IsHitTestVisible="False"
                   Opacity="0.52"
                   PlaceholderText="Search conversations"
                   Padding="14"
                   Margin="{StaticResource InsetSearchNarrow}"
                   HorizontalAlignment="Stretch" />
          <StackPanel x:Name="NarrowRowStack" Grid.Row="1" Spacing="2" />
        </Grid>
      </ScrollViewer>
    </Grid>

    <!-- narrow thread -->
    <Grid x:Name="NarrowThreadPane" Visibility="Collapsed">
      <Frame x:Name="NarrowThreadFrame" Background="{ThemeResource BgBrush}" />
    </Grid>
  </Grid>

</Page>
