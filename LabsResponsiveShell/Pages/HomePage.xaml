<Page x:Class="LabsResponsiveShell.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Foreground="{ThemeResource TextBrush}">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Padding="24,28,24,32"
          MaxWidth="1080"
          HorizontalAlignment="Left">

      <!-- scoped glow: fades across the top band, only on Home -->
      <Rectangle Fill="{ThemeResource AuroraGlowBrush}"
                 Height="320"
                 VerticalAlignment="Top"
                 IsHitTestVisible="False" />

      <StackPanel Spacing="32">

        <!-- welcome card -->
        <Border Background="{ThemeResource SurfaceBrush}"
                BorderBrush="{ThemeResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius20}"
                Padding="28,26,28,26">
          <StackPanel Spacing="10">
            <TextBlock Style="{StaticResource EyebrowText}" Text="TODAY" />
            <TextBlock Style="{StaticResource HeroText}"
                       Text="Hello"
                       FontSize="{StaticResource FontSize56}"
                       LineHeight="60" />
            <TextBlock Style="{StaticResource MutedText}"
                       Text="You have 12 new messages today." />
          </StackPanel>
        </Border>

        <!-- recent conversations -->
        <StackPanel Spacing="14">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Style="{StaticResource EyebrowText}" Text="RECENT CONVERSATIONS" />
            <HyperlinkButton Grid.Column="1"
                             Content="View all"
                             Padding="0"
                             Click="OnViewAllClick" />
          </Grid>
          <Border Background="{ThemeResource SurfaceBrush}"
                  BorderBrush="{ThemeResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{StaticResource Radius16}"
                  Padding="8">
            <StackPanel x:Name="RecentStack" Spacing="2" />
          </Border>
        </StackPanel>

        <!-- quick actions -->
        <StackPanel Spacing="14">
          <TextBlock Style="{StaticResource EyebrowText}" Text="QUICK ACTIONS" />
          <Grid ColumnSpacing="16" ColumnDefinitions="*,*,*">
            <Button Grid.Column="0"
                    Tag="New chat"
                    Click="OnQuickActionClick"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius16}"
                    Padding="18,16,18,16">
              <StackPanel Spacing="12">
                <Grid Width="40" Height="40">
                  <Ellipse Fill="{ThemeResource AccentMutedBrush}" />
                  <PathIcon Data="{StaticResource IconPlusChatData}"
                            Width="20"
                            Height="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource AccentBrush}" />
                </Grid>
                <TextBlock Text="New chat"
                           FontFamily="{StaticResource PrimaryFontFamily}"
                           FontSize="{StaticResource FontSize15}"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextBrush}" />
                <TextBlock Style="{StaticResource CaptionText}" Text="Start a direct message" />
              </StackPanel>
            </Button>
            <Button Grid.Column="1"
                    Tag="New group"
                    Click="OnQuickActionClick"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius16}"
                    Padding="18,16,18,16">
              <StackPanel Spacing="12">
                <Grid Width="40" Height="40">
                  <Ellipse Fill="{ThemeResource AccentMutedBrush}" />
                  <PathIcon Data="{StaticResource IconUsersData}"
                            Width="20"
                            Height="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource AccentBrush}" />
                </Grid>
                <TextBlock Text="New group"
                           FontFamily="{StaticResource PrimaryFontFamily}"
                           FontSize="{StaticResource FontSize15}"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextBrush}" />
                <TextBlock Style="{StaticResource CaptionText}" Text="Gather a team thread" />
              </StackPanel>
            </Button>
            <Button Grid.Column="2"
                    Tag="Browse channels"
                    Click="OnQuickActionClick"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius16}"
                    Padding="18,16,18,16">
              <StackPanel Spacing="12">
                <Grid Width="40" Height="40">
                  <Ellipse Fill="{ThemeResource AccentMutedBrush}" />
                  <PathIcon Data="{StaticResource IconRadioData}"
                            Width="20"
                            Height="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource AccentBrush}" />
                </Grid>
                <TextBlock Text="Browse channels"
                           FontFamily="{StaticResource PrimaryFontFamily}"
                           FontSize="{StaticResource FontSize15}"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextBrush}" />
                <TextBlock Style="{StaticResource CaptionText}" Text="Find public rooms" />
              </StackPanel>
            </Button>
          </Grid>
        </StackPanel>

        <!-- activity chips -->
        <StackPanel Spacing="14">
          <TextBlock Style="{StaticResource EyebrowText}" Text="ACTIVITY" />
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Border Background="{ThemeResource SurfaceElevatedBrush}"
                    BorderBrush="{ThemeResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="999"
                    Padding="14,8,14,8">
              <TextBlock Style="{StaticResource EyebrowText}" Text="12 NEW MESSAGES TODAY" />
            </Border>
            <Border Background="{ThemeResource SurfaceElevatedBrush}"
                    BorderBrush="{ThemeResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="999"
                    Padding="14,8,14,8">
              <TextBlock Style="{StaticResource EyebrowText}" Text="3 UNREAD THREADS" />
            </Border>
            <Border Background="{ThemeResource SurfaceElevatedBrush}"
                    BorderBrush="{ThemeResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="999"
                    Padding="14,8,14,8">
              <TextBlock Style="{StaticResource EyebrowText}" Text="2 PENDING INVITES" />
            </Border>
          </StackPanel>
        </StackPanel>

      </StackPanel>
    </Grid>
  </ScrollViewer>

</Page>
