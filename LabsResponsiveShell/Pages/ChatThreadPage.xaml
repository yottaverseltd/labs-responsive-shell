<Page x:Class="LabsResponsiveShell.Pages.ChatThreadPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:LabsResponsiveShell.Controls"
      Background="{ThemeResource BgBrush}"
      Foreground="{ThemeResource TextBrush}">

  <Grid RowDefinitions="Auto,*">
    <Grid Grid.Row="0"
          Padding="{StaticResource InsetThreadBackBar}"
          BorderBrush="{ThemeResource BorderBrush}"
          BorderThickness="0,0,0,1"
          Background="{ThemeResource SurfaceBrush}">
      <Button Grid.Column="0"
              Click="OnBackClick"
              Content="Back"
              Background="{ThemeResource TransparentChromeBrush}"
              BorderThickness="0"
              Padding="14,12"
              Foreground="{ThemeResource TextBrush}" />
    </Grid>
    <controls:ChatConversationChrome x:Name="Chrome" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
  </Grid>

</Page>
