<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ResourceDictionary.ThemeDictionaries>

    <ResourceDictionary x:Key="Default">
      <Color x:Key="BgColor">#0B0D10</Color>
      <Color x:Key="SurfaceColor">#141820</Color>
      <Color x:Key="SurfaceElevatedColor">#1C2230</Color>
      <Color x:Key="TextColor">#F2F4F8</Color>
      <Color x:Key="TextMutedColor">#8B95A7</Color>
      <Color x:Key="AccentColor">#2DD4BF</Color>
      <Color x:Key="AccentStrongColor">#14B8A6</Color>
      <Color x:Key="AccentMutedColor">#134E4A</Color>
      <Color x:Key="BorderColor">#232A38</Color>
      <Color x:Key="HoverColor">#1A2030</Color>

      <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}" />
      <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
      <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}" />
      <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
      <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
      <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
      <SolidColorBrush x:Key="AccentStrongBrush" Color="{StaticResource AccentStrongColor}" />
      <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMutedColor}" />
      <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
      <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}" />

      <Color x:Key="BubbleMineColor">#243A44</Color>
      <SolidColorBrush x:Key="BubbleMineBrush" Color="{StaticResource BubbleMineColor}" />
      <SolidColorBrush x:Key="BubbleTheirsBrush" Color="{StaticResource SurfaceElevatedColor}" />

      <Color x:Key="PresenceOnlineColor">#22C55E</Color>
      <Color x:Key="PresenceAwayColor">#CA8A06</Color>
      <SolidColorBrush x:Key="PresenceOnlineBrush" Color="{StaticResource PresenceOnlineColor}" />
      <SolidColorBrush x:Key="PresenceAwayBrush" Color="{StaticResource PresenceAwayColor}" />

      <SolidColorBrush x:Key="UnreadBadgeBackgroundBrush" Color="{StaticResource AccentStrongColor}" />
      <SolidColorBrush x:Key="UnreadBadgeForegroundBrush" Color="#FFFFFFFF" />

      <SolidColorBrush x:Key="ConversationRowSelectedBrush" Opacity="0.45" Color="{StaticResource AccentMutedColor}" />

      <Color x:Key="AvatarTone0Color">#2A3548</Color>
      <Color x:Key="AvatarTone1Color">#3A2F45</Color>
      <Color x:Key="AvatarTone2Color">#243A36</Color>
      <Color x:Key="AvatarTone3Color">#3A3828</Color>
      <Color x:Key="AvatarTone4Color">#2C3042</Color>
      <Color x:Key="AvatarTone5Color">#254045</Color>
      <SolidColorBrush x:Key="AvatarTone0Brush" Color="{StaticResource AvatarTone0Color}" />
      <SolidColorBrush x:Key="AvatarTone1Brush" Color="{StaticResource AvatarTone1Color}" />
      <SolidColorBrush x:Key="AvatarTone2Brush" Color="{StaticResource AvatarTone2Color}" />
      <SolidColorBrush x:Key="AvatarTone3Brush" Color="{StaticResource AvatarTone3Color}" />
      <SolidColorBrush x:Key="AvatarTone4Brush" Color="{StaticResource AvatarTone4Color}" />
      <SolidColorBrush x:Key="AvatarTone5Brush" Color="{StaticResource AvatarTone5Color}" />
    </ResourceDictionary>

    <ResourceDictionary x:Key="Light">
      <Color x:Key="BgColor">#FAF7F0</Color>
      <Color x:Key="SurfaceColor">#FFFFFF</Color>
      <Color x:Key="SurfaceElevatedColor">#F3EEE3</Color>
      <Color x:Key="TextColor">#111114</Color>
      <Color x:Key="TextMutedColor">#5A5F6A</Color>
      <Color x:Key="AccentColor">#0D9488</Color>
      <Color x:Key="AccentStrongColor">#0F766E</Color>
      <Color x:Key="AccentMutedColor">#CCFBF1</Color>
      <Color x:Key="BorderColor">#E8E1D0</Color>
      <Color x:Key="HoverColor">#F0EADB</Color>

      <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}" />
      <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
      <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}" />
      <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
      <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
      <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
      <SolidColorBrush x:Key="AccentStrongBrush" Color="{StaticResource AccentStrongColor}" />
      <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMutedColor}" />
      <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
      <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}" />

      <Color x:Key="BubbleMineColor">#D8F2EC</Color>
      <SolidColorBrush x:Key="BubbleMineBrush" Color="{StaticResource BubbleMineColor}" />
      <SolidColorBrush x:Key="BubbleTheirsBrush" Color="{StaticResource SurfaceElevatedColor}" />

      <Color x:Key="PresenceOnlineColor">#15803D</Color>
      <Color x:Key="PresenceAwayColor">#CA8A06</Color>
      <SolidColorBrush x:Key="PresenceOnlineBrush" Color="{StaticResource PresenceOnlineColor}" />
      <SolidColorBrush x:Key="PresenceAwayBrush" Color="{StaticResource PresenceAwayColor}" />

      <SolidColorBrush x:Key="UnreadBadgeBackgroundBrush" Color="{StaticResource AccentStrongColor}" />
      <SolidColorBrush x:Key="UnreadBadgeForegroundBrush" Color="#FFFFFFFF" />

      <SolidColorBrush x:Key="ConversationRowSelectedBrush" Opacity="0.55" Color="{StaticResource AccentMutedColor}" />

      <Color x:Key="AvatarTone0Color">#DCE6F5</Color>
      <Color x:Key="AvatarTone1Color">#E8DCF0</Color>
      <Color x:Key="AvatarTone2Color">#D8EDE8</Color>
      <Color x:Key="AvatarTone3Color">#EEE8D8</Color>
      <Color x:Key="AvatarTone4Color">#E0E4F2</Color>
      <Color x:Key="AvatarTone5Color">#D6EBEE</Color>
      <SolidColorBrush x:Key="AvatarTone0Brush" Color="{StaticResource AvatarTone0Color}" />
      <SolidColorBrush x:Key="AvatarTone1Brush" Color="{StaticResource AvatarTone1Color}" />
      <SolidColorBrush x:Key="AvatarTone2Brush" Color="{StaticResource AvatarTone2Color}" />
      <SolidColorBrush x:Key="AvatarTone3Brush" Color="{StaticResource AvatarTone3Color}" />
      <SolidColorBrush x:Key="AvatarTone4Brush" Color="{StaticResource AvatarTone4Color}" />
      <SolidColorBrush x:Key="AvatarTone5Brush" Color="{StaticResource AvatarTone5Color}" />
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>

  <x:Double x:Key="Space4">4</x:Double>
  <x:Double x:Key="Space8">8</x:Double>
  <x:Double x:Key="Space10">10</x:Double>
  <x:Double x:Key="Space12">12</x:Double>
  <x:Double x:Key="Space16">16</x:Double>
  <x:Double x:Key="Space24">24</x:Double>
  <x:Double x:Key="Space32">32</x:Double>
  <x:Double x:Key="Space48">48</x:Double>
  <x:Double x:Key="Space64">64</x:Double>

  <CornerRadius x:Key="Radius8">8</CornerRadius>
  <CornerRadius x:Key="Radius12">12</CornerRadius>
  <CornerRadius x:Key="Radius16">16</CornerRadius>
  <CornerRadius x:Key="Radius20">20</CornerRadius>

  <x:String x:Key="FontFamilyBase">Inter, Segoe UI, -apple-system, system-ui, sans-serif</x:String>

  <x:Double x:Key="FontSize11">11</x:Double>
  <x:Double x:Key="FontSize12">12</x:Double>
  <x:Double x:Key="FontSize14">14</x:Double>
  <x:Double x:Key="FontSize15">15</x:Double>
  <x:Double x:Key="FontSize16">16</x:Double>
  <x:Double x:Key="FontSize18">18</x:Double>
  <x:Double x:Key="FontSize20">20</x:Double>
  <x:Double x:Key="FontSize24">24</x:Double>
  <x:Double x:Key="FontSize28">28</x:Double>
  <x:Double x:Key="FontSize32">32</x:Double>
  <x:Double x:Key="FontSize40">40</x:Double>
  <x:Double x:Key="FontSize56">56</x:Double>

  <x:Double x:Key="ReadingColumnMaxWidth">640</x:Double>
  <x:Double x:Key="ShellContentMaxWidth">1240</x:Double>
  <x:Double x:Key="NavRailWidth">240</x:Double>

  <CornerRadius x:Key="RadiusChatMine">16,16,6,16</CornerRadius>
  <CornerRadius x:Key="RadiusChatTheirs">16,16,16,6</CornerRadius>

  <Thickness x:Key="InsetChatRail">16,24,16,24</Thickness>
  <Thickness x:Key="InsetThreadBackBar">16,12,16,10</Thickness>
  <Thickness x:Key="InsetDateChipPad">12,4,12,4</Thickness>
  <Thickness x:Key="InsetChromeHeader">16,16,16,14</Thickness>
  <Thickness x:Key="InsetComposerChrome">16,12,16,16</Thickness>
  <Thickness x:Key="InsetTypingStripe">16,16,16,16</Thickness>
  <Thickness x:Key="InsetTypingBubble">16,10,16,10</Thickness>
  <Thickness x:Key="InsetVoiceFoot">16,14,24,26</Thickness>
  <Thickness x:Key="InsetSearchWide">10,12,14,26</Thickness>
  <Thickness x:Key="InsetSearchNarrow">10,18,14,26</Thickness>

  <x:Double x:Key="GrainOpacity">0.027</x:Double>

  <ImageBrush x:Key="GrainTileBrush"
              ImageSource="ms-appx:///Assets/grain.png"
              Stretch="UniformToFill" />

  <SolidColorBrush x:Key="TransparentChromeBrush" Color="#00000000" />

</ResourceDictionary>
