<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- why: runtime clamps these to zero when ReducedMotion.IsReducedMotion is true -->
  <Duration x:Key="MotionFast">0:0:0.120</Duration>
  <Duration x:Key="MotionDefault">0:0:0.200</Duration>
  <Duration x:Key="MotionSlow">0:0:0.320</Duration>

  <CubicEase x:Key="EaseStandard" EasingMode="EaseInOut" />
  <CubicEase x:Key="EaseOut" EasingMode="EaseOut" />
  <CubicEase x:Key="EaseIn" EasingMode="EaseIn" />

</ResourceDictionary>
