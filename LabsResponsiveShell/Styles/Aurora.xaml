<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ResourceDictionary.ThemeDictionaries>

    <ResourceDictionary x:Key="Default">
      <LinearGradientBrush x:Key="AuroraGlassBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1FFFFFFF" Offset="0" />
        <GradientStop Color="#0AFFFFFF" Offset="1" />
      </LinearGradientBrush>
      <RadialGradientBrush x:Key="AuroraGlowBrush" Center="0.5,0.0" RadiusX="0.9" RadiusY="0.7">
        <GradientStop Color="#507DA3FF" Offset="0" />
        <GradientStop Color="#00000000" Offset="1" />
      </RadialGradientBrush>
    </ResourceDictionary>

    <ResourceDictionary x:Key="Light">
      <LinearGradientBrush x:Key="AuroraGlassBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#14000000" Offset="0" />
        <GradientStop Color="#05000000" Offset="1" />
      </LinearGradientBrush>
      <RadialGradientBrush x:Key="AuroraGlowBrush" Center="0.5,0.0" RadiusX="0.9" RadiusY="0.7">
        <GradientStop Color="#402B59FF" Offset="0" />
        <GradientStop Color="#00000000" Offset="1" />
      </RadialGradientBrush>
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
