<UserControl x:Class="LabsResponsiveShell.Controls.ChatConversationChrome"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:data="using:LabsResponsiveShell.Data"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sel="using:LabsResponsiveShell.Pages.Selectors"
             x:Name="ChromeRoot"
             mc:Ignorable="d">

  <UserControl.Resources>
    <sel:ChatThreadTemplateSelector x:Key="ThreadTemplates"
                                    DateTemplate="{StaticResource DtDate}"
                                    TextMineTemplate="{StaticResource DtMine}"
                                    TextTheirTemplate="{StaticResource DtTheir}"
                                    LinkTemplate="{StaticResource DtLink}"
                                    ImageTemplate="{StaticResource DtImg}"
                                    VoiceTemplate="{StaticResource DtVoice}" />

    <DataTemplate x:Key="DtDate" x:DataType="data:MockThreadItem">
      <Border HorizontalAlignment="Center"
              Margin="{x:Bind ChatRowPadding}"
              Padding="{StaticResource InsetDateChipPad}"
              CornerRadius="{StaticResource Radius16}"
              Background="{ThemeResource SurfaceElevatedBrush}">
        <TextBlock Text="{x:Bind Body}" Style="{StaticResource EyebrowText}" />
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="DtTheir" x:DataType="data:MockThreadItem">
      <Grid HorizontalAlignment="Left"
            Margin="{x:Bind ChatRowPadding}"
            MaxWidth="{Binding ElementName=ChromeRoot, Path=BubbleCapWidth}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Ellipse Grid.Column="0"
                 Width="32"
                 Height="32"
                 Margin="0,0,12,0"
                 VerticalAlignment="Top"
                 Fill="{ThemeResource AvatarTone3Brush}"
                 Visibility="{x:Bind ShowAvatar, Mode=OneWay, Converter={StaticResource BoolVisibilityConverter}}" />
        <Grid Grid.Column="1" HorizontalAlignment="Left">
          <StackPanel Spacing="{StaticResource Space8}">
            <Border Padding="{StaticResource Space12}"
                    CornerRadius="{StaticResource RadiusChatTheirs}"
                    Background="{ThemeResource BubbleTheirsBrush}">
              <StackPanel Spacing="{StaticResource Space8}">
                <StackPanel Visibility="{x:Bind ReplyQuoteAuthor, Converter={StaticResource NonEmptyStringVisibilityConverter}, TargetNullValue=Collapsed}">
                  <Rectangle Height="4" RadiusX="2" RadiusY="2" Fill="{ThemeResource AccentMutedBrush}" Opacity="0.44" Margin="0,0,0,6" />
                  <TextBlock Text="{x:Bind ReplyQuoteAuthor}" Style="{StaticResource CaptionText}" />
                  <TextBlock Text="{x:Bind ReplyQuoteSnippet}" Style="{StaticResource CaptionText}" MaxLines="2" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
                </StackPanel>
                <TextBlock Text="{x:Bind Body}"
                           Style="{StaticResource ChatBubbleText}"
                           Foreground="{ThemeResource TextBrush}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <Border Margin="14,2,8,-10"
                    Padding="12,6"
                    HorizontalAlignment="Left"
                    CornerRadius="999"
                    Background="{ThemeResource SurfaceElevatedBrush}"
                    BorderBrush="{ThemeResource BorderBrush}"
                    BorderThickness="1"
                    Visibility="{x:Bind ReactionCount, Mode=OneWay, Converter={StaticResource PositiveCountVisibilityConverter}}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <SymbolIcon Symbol="Favorite" Width="14" Height="14" VerticalAlignment="Center" Foreground="{ThemeResource AccentStrongBrush}" />
                <TextBlock Text="{x:Bind ReactionCount}" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
              </StackPanel>
            </Border>
            <TextBlock Margin="8,14,8,4"
                       Text="{x:Bind RelativeTimeLabel}"
                       Style="{StaticResource CaptionText}"
                       Opacity="0.74" />
          </StackPanel>
        </Grid>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="DtMine" x:DataType="data:MockThreadItem">
      <Grid HorizontalAlignment="Right"
            Margin="{x:Bind ChatRowPadding}"
            MaxWidth="{Binding ElementName=ChromeRoot, Path=BubbleCapWidth}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="{StaticResource Space8}">
          <Border Padding="{StaticResource Space12}"
                  CornerRadius="{StaticResource RadiusChatMine}"
                  Background="{ThemeResource BubbleMineBrush}"
                  HorizontalAlignment="Right">
            <StackPanel Spacing="{StaticResource Space8}">
              <StackPanel Visibility="{x:Bind ReplyQuoteAuthor, Converter={StaticResource NonEmptyStringVisibilityConverter}, TargetNullValue=Collapsed}">
                <Rectangle Height="4" RadiusX="2" RadiusY="2" Fill="{ThemeResource AccentMutedBrush}" Opacity="0.5" Margin="0,0,0,6" />
                <TextBlock Text="{x:Bind ReplyQuoteAuthor}" Style="{StaticResource CaptionText}" />
                <TextBlock Text="{x:Bind ReplyQuoteSnippet}" Style="{StaticResource CaptionText}" MaxLines="2" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
              </StackPanel>
              <TextBlock Text="{x:Bind Body}"
                         Style="{StaticResource ChatBubbleText}"
                         Foreground="{ThemeResource TextBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <Border Margin="8,6,10,-12"
                  Padding="12,6"
                  HorizontalAlignment="Right"
                  CornerRadius="999"
                  Background="{ThemeResource SurfaceElevatedBrush}"
                  BorderBrush="{ThemeResource BorderBrush}"
                  BorderThickness="1"
                  Visibility="{x:Bind ReactionCount, Mode=OneWay, Converter={StaticResource PositiveCountVisibilityConverter}}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <SymbolIcon Symbol="Favorite" Width="14" Height="14" VerticalAlignment="Center" Foreground="{ThemeResource AccentStrongBrush}" />
              <TextBlock Text="{x:Bind ReactionCount}" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
            </StackPanel>
          </Border>
          <Grid Margin="12,14,14,12" HorizontalAlignment="Right">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{x:Bind RelativeTimeLabel}"
                       Style="{StaticResource CaptionText}"
                       Opacity="0.74"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0" />
            <Ellipse Grid.Column="1"
                     Width="32"
                     Height="32"
                     VerticalAlignment="Top"
                     Fill="{ThemeResource AccentMutedBrush}"
                     Visibility="{x:Bind ShowAvatar, Mode=OneWay, Converter={StaticResource BoolVisibilityConverter}}" />
          </Grid>
        </StackPanel>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="DtLink" x:DataType="data:MockThreadItem">
      <Grid HorizontalAlignment="Left"
            Margin="{x:Bind ChatRowPadding}"
            MaxWidth="{Binding ElementName=ChromeRoot, Path=BubbleCapWidth}">
        <Border Padding="{StaticResource Space12}"
                CornerRadius="{StaticResource RadiusChatTheirs}"
                Background="{ThemeResource BubbleTheirsBrush}">
          <StackPanel Spacing="{StaticResource Space12}">
            <Border CornerRadius="{StaticResource Radius8}"
                    Height="118"
                    Width="268"
                    HorizontalAlignment="Left"
                    Background="{ThemeResource AccentMutedBrush}" />
            <TextBlock Text="{x:Bind LinkTitle}"
                       Style="{StaticResource TitleText}"
                       FontSize="{StaticResource FontSize15}"
                       LineHeight="20"
                       TextWrapping="Wrap"
                       MaxLines="2"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Text="{x:Bind LinkDescription}" Style="{StaticResource CaptionText}" TextWrapping="Wrap" MaxLines="3" TextTrimming="CharacterEllipsis" />
            <TextBlock Text="{x:Bind LinkDomain}" Style="{StaticResource CaptionText}" />
            <TextBlock Text="{x:Bind RelativeTimeLabel}" Style="{StaticResource CaptionText}" Opacity="0.65" />
          </StackPanel>
        </Border>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="DtImg" x:DataType="data:MockThreadItem">
      <Grid HorizontalAlignment="Right"
            Margin="{x:Bind ChatRowPadding}"
            MaxWidth="{Binding ElementName=ChromeRoot, Path=BubbleCapWidth}">
        <Border Padding="{StaticResource Space12}"
                CornerRadius="{StaticResource RadiusChatMine}"
                Background="{ThemeResource BubbleMineBrush}">
          <StackPanel Spacing="{StaticResource Space8}">
            <Border Width="276"
                    Height="207"
                    CornerRadius="{StaticResource Radius16}"
                    Background="{ThemeResource AccentStrongBrush}" />
            <TextBlock Text="{x:Bind ImageCaption}" Style="{StaticResource CaptionText}" />
            <TextBlock Text="{x:Bind RelativeTimeLabel}" Style="{StaticResource CaptionText}" Opacity="0.72" />
          </StackPanel>
        </Border>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="DtVoice" x:DataType="data:MockThreadItem">
      <Grid HorizontalAlignment="Left"
            Margin="{x:Bind ChatRowPadding}"
            MaxWidth="{Binding ElementName=ChromeRoot, Path=BubbleCapWidth}">
        <Border Padding="{StaticResource Space12}"
                CornerRadius="{StaticResource RadiusChatTheirs}"
                Background="{ThemeResource BubbleTheirsBrush}">
          <StackPanel Spacing="{StaticResource Space10}">
            <Grid ColumnDefinitions="Auto,*,Auto">
              <SymbolIcon Grid.Column="0"
                          Symbol="Microphone"
                          Width="28"
                          Height="28"
                          Margin="0,8,14,8"
                          VerticalAlignment="Center" />
              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Spacing="5">
                <Rectangle Width="5" Height="26" RadiusX="2" RadiusY="2" Fill="{ThemeResource AccentBrush}" Opacity="0.45" />
                <Rectangle Width="5" Height="18" RadiusX="2" RadiusY="2" Fill="{ThemeResource AccentBrush}" Opacity="0.88" />
                <Rectangle Width="5" Height="36" RadiusX="2" RadiusY="2" Fill="{ThemeResource AccentBrush}" Opacity="0.95" />
                <Rectangle Width="5" Height="21" RadiusX="2" RadiusY="2" Fill="{ThemeResource AccentBrush}" Opacity="0.58" />
                <Rectangle Width="5" Height="14" RadiusX="2" RadiusY="2" Fill="{ThemeResource AccentBrush}" Opacity="0.44" />
                <Rectangle Width="5" Height="31" RadiusX="2" RadiusY="2" Fill="{ThemeResource AccentBrush}" Opacity="0.78" />
                <Rectangle Width="5" Height="17" RadiusX="2" RadiusY="2" Fill="{ThemeResource AccentBrush}" Opacity="0.52" />
                <Rectangle Width="5" Height="24" RadiusX="2" RadiusY="2" Fill="{ThemeResource AccentBrush}" Opacity="0.66" />
                <Rectangle Width="5" Height="13" RadiusX="2" RadiusY="2" Fill="{ThemeResource AccentBrush}" Opacity="0.48" />
                <Rectangle Width="5" Height="29" RadiusX="2" RadiusY="2" Fill="{ThemeResource AccentBrush}" Opacity="0.72" />
              </StackPanel>
              <Grid Grid.Column="2" Margin="22,12,24,12" Width="48" Height="48" HorizontalAlignment="Right">
                <Ellipse Fill="{ThemeResource AccentMutedBrush}" />
                <SymbolIcon Symbol="Play" Width="26" Height="26" Margin="17,17,17,17" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource TextBrush}" />
              </Grid>
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="16" Margin="{StaticResource InsetVoiceFoot}">
              <TextBlock Text="{x:Bind VoiceDuration}" Style="{StaticResource CaptionText}" />
              <TextBlock Text="{x:Bind RelativeTimeLabel}" Style="{StaticResource CaptionText}" Opacity="0.65" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </DataTemplate>

  </UserControl.Resources>

  <Border Background="{ThemeResource SurfaceBrush}">
    <!-- grain shell applied on cards elsewhere; composer panel stays calm -->
    <Grid RowDefinitions="Auto,*,Auto,Auto">

      <!-- header -->
      <Grid Grid.Row="0"
            Padding="{StaticResource InsetChromeHeader}"
            ColumnDefinitions="*,Auto"
            BorderBrush="{ThemeResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Background="{ThemeResource SurfaceBrush}">
        <StackPanel Orientation="Horizontal" Spacing="14" HorizontalAlignment="Left">
          <Grid Width="54" Height="54" Margin="0,6,14,12" HorizontalAlignment="Left">
            <Ellipse x:Name="HeaderAvatarGlow"
                     Width="48"
                     Height="48"
                     Fill="{ThemeResource AccentMutedBrush}" />
            <Ellipse x:Name="HeaderAvatar"
                     Width="48"
                     Height="48"
                     Fill="{ThemeResource AvatarTone5Brush}"
                     Stroke="{ThemeResource BorderBrush}"
                     StrokeThickness="1" />
            <TextBlock x:Name="HeaderInitials"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontFamily="{StaticResource PrimaryFontFamily}"
                       FontSize="{StaticResource FontSize14}"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextBrush}" />
          </Grid>
          <StackPanel VerticalAlignment="Center" Spacing="3">
            <TextBlock x:Name="HeaderTitleText" Style="{StaticResource TitleText}" FontSize="{StaticResource FontSize18}" LineHeight="24" />
            <TextBlock x:Name="HeaderSubtitleText" Style="{StaticResource CaptionText}" />
          </StackPanel>
        </StackPanel>
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Spacing="12">
          <Border Width="52" Height="52" CornerRadius="26" Padding="13,13">
            <SymbolIcon Symbol="Phone" Opacity="0.45" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="26" Padding="11,13">
            <SymbolIcon Symbol="SlideShow" Opacity="0.45" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="26" Padding="13,13">
            <SymbolIcon Symbol="Setting" Opacity="0.45" />
          </Border>
        </StackPanel>
      </Grid>

      <ScrollViewer x:Name="ThreadScroller"
                    Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    Padding="{StaticResource Space16}">
        <ItemsControl x:Name="ThreadItems"
                      ItemTemplateSelector="{StaticResource ThreadTemplates}" />
      </ScrollViewer>

      <Border x:Name="TypingStripe"
              Grid.Row="2"
              Padding="{StaticResource Space16}"
              Visibility="Collapsed"
              BorderBrush="{ThemeResource BorderBrush}"
              BorderThickness="0,1,0,0"
              Background="{ThemeResource SurfaceBrush}">
        <StackPanel Orientation="Vertical" Spacing="8">
          <TextBlock x:Name="TypingLabel" Style="{StaticResource CaptionText}" />
          <Border Padding="16,10"
                  HorizontalAlignment="Left"
                  CornerRadius="{StaticResource Radius20}"
                  Background="{ThemeResource SurfaceElevatedBrush}">
            <StackPanel x:Name="TypingDotsStrip" Orientation="Horizontal" Spacing="8">
              <Ellipse x:Name="TypingDotA" Width="8" Height="8" Fill="{ThemeResource AccentBrush}" Opacity="0.4" />
              <Ellipse x:Name="TypingDotB" Width="8" Height="8" Fill="{ThemeResource AccentBrush}" Opacity="0.4" />
              <Ellipse x:Name="TypingDotC" Width="8" Height="8" Fill="{ThemeResource AccentBrush}" Opacity="0.4" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Border Grid.Row="3"
              Background="{ThemeResource SurfaceBrush}"
              BorderBrush="{ThemeResource BorderBrush}"
              BorderThickness="0,1,0,0"
              Padding="{StaticResource InsetComposerChrome}">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
          <Border Grid.Column="0" Padding="{StaticResource Space8}" Margin="6,10,14,12" HorizontalAlignment="Left">
            <SymbolIcon Symbol="Attach" Width="26" Height="26" Opacity="0.55" IsTapEnabled="False" />
          </Border>
          <TextBox x:Name="DraftBox"
                   Grid.Column="1"
                   MinHeight="44"
                   VerticalAlignment="Center"
                   PlaceholderText="Message"
                   TextChanged="OnDraftChanged" />
          <Border Grid.Column="2" Padding="{StaticResource Space8}" Margin="12,10,10,12" HorizontalAlignment="Left">
            <SymbolIcon Symbol="Emoji2" Width="26" Height="26" Opacity="0.55" IsTapEnabled="False" />
          </Border>
          <Button x:Name="SendButton"
                  Grid.Column="3"
                  MinWidth="60"
                  Click="OnSendClick"
                  IsEnabled="False"
                  Content="Send"
                  Background="{ThemeResource AccentStrongBrush}"
                  Foreground="{ThemeResource UnreadBadgeForegroundBrush}"
                  CornerRadius="{StaticResource Radius16}"
                  HorizontalAlignment="Right"
                  Margin="14,12,14,14" />
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>
